    {
      "type": "rectangle",
      "id": "deploy_options",
      "x": 50,
      "y": 265,
      "width": 880,
      "height": 100,
      "roundness": { "type": 3 },
      "backgroundColor": "#c3fae8",
      "fillStyle": "solid",
      "boundElements": [{ "id": "t_deploy", "type": "text" }]
    },
    {
      "type": "text",
      "id": "t_deploy",
      "x": 60,
      "y": 275,
      "width": 860,
      "height": 80,
      "text": "📋 Admin copies & runs one of these on target server:\n\n   curl -L .../anj-agent | ./anj-agent register --server ... --token REG_TOKEN\n   docker run -d --name anj-agent ... ghcr.io/edsuwarna/anj-agent:latest\n   docker compose up -d (with anj-agent service)",
      "fontSize": 16,
      "fontFamily": 1,
      "strokeColor": "#1e1e1e",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": "deploy_options",
      "originalText": "📋 Admin copies & runs one of these on target server:\n\n   curl -L .../anj-agent | ./anj-agent register --server ... --token REG_TOKEN\n   docker run -d --name anj-agent ... ghcr.io/edsuwarna/anj-agent:latest\n   docker compose up -d (with anj-agent service)",
      "autoResize": true
    },

