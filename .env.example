# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=anjungan
POSTGRES_PASSWORD=anjungan
POSTGRES_DB=anjungan
POSTGRES_SSLMODE=disable

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# ─── Server ──────────────────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
LOG_LEVEL=info

# ─── SSH ─────────────────────────────────────────────────────────────────────
SSH_HOST_KEY_PATH=/data/ssh/id_ed25519
SSH_DEFAULT_PORT=22

# ─── GitHub Integration ──────────────────────────────────────────────────────
GITHUB_TOKEN=

# ─── Container Registry ──────────────────────────────────────────────────────
REGISTRY_URL=http://zot:5000
